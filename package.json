{
  "name": "@loc/electron-window",
  "version": "0.0.0-development",
  "description": "Declarative React components for Electron window management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./main": {
      "types": "./dist/main/index.d.ts",
      "default": "./dist/main/index.js"
    },
    "./preload": {
      "types": "./dist/preload/index.d.ts",
      "default": "./dist/preload/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/preload/index.js",
    "./src/preload/index.ts",
    "./src/generated-ipc/preload/electron_window.ts",
    "./src/generated-ipc/_internal/preload/electron_window.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate:ipc": "generate-ipc schemas src/generated-ipc",
    "prebuild": "yarn generate:ipc",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "pretest:e2e": "yarn build && node tests/e2e/fixtures/test-app/build.js",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "electron": ">=30.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@marshallofsound/ipc": "^2.6.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.1.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "electron": "^33.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.55.0",
    "jsdom": "^23.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/loc/electron-window.git"
  },
  "keywords": [
    "electron",
    "react",
    "window",
    "browserwindow",
    "declarative"
  ],
  "author": "Andy Locascio",
  "license": "MIT"
}
