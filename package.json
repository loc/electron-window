{
  "name": "@loc/electron-window",
  "version": "0.0.0-development",
  "description": "Declarative React components for Electron window management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./main": {
      "types": "./dist/main/index.d.ts",
      "import": "./dist/main/index.js",
      "require": "./dist/main/index.cjs"
    },
    "./preload": {
      "types": "./dist/preload/index.d.ts",
      "import": "./dist/preload/index.js",
      "require": "./dist/preload/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/preload/index.js",
    "./dist/preload/index.cjs",
    "./src/preload/**",
    "./src/generated-ipc/**/preload/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate:ipc": "generate-ipc schemas src/generated-ipc",
    "postgenerate:ipc": "node scripts/patch-ipc-validators.mjs",
    "prebuild": "yarn generate:ipc",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "pretest:e2e": "yarn build && node tests/e2e/fixtures/test-app/build.js",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "docs:dev": "cd docs && yarn dev",
    "docs:build": "cd docs && yarn build",
    "clean": "rm -rf dist",
    "prepublishOnly": "yarn build"
  },
  "peerDependencies": {
    "electron": ">=30.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "devDependencies": {
    "@marshallofsound/ipc": "~2.6.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.1.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "electron": "^33.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.55.0",
    "jsdom": "^23.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "semantic-release": "^24.0.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/github": "^11.0.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/loc/electron-window.git"
  },
  "homepage": "https://loc.github.io/electron-window/",
  "bugs": {
    "url": "https://github.com/loc/electron-window/issues"
  },
  "keywords": [
    "electron",
    "react",
    "window",
    "browserwindow",
    "declarative"
  ],
  "author": "Andy Locascio",
  "license": "MIT"
}
